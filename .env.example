# LiteLLM proxy connection (edit these before running generate-settings)
LITELLM_HOST="YOUR_LITELLM_HOST"
LITELLM_PORT="4000"
LITELLM_URL="http://$LITELLM_HOST:$LITELLM_PORT"
LITELLM_API_KEY="YOUR_LITELLM_API_KEY"
OLLAMA_HOST="YOUR_OLLAMA_HOST"
OLLAMA_PORT="11434"
OLLAMA_URL="http://$OLLAMA_HOST:$OLLAMA_PORT"

# Optional: pin specific models (overrides auto-detect)
# SONNET_MODEL="deepseek-v4-flash"
# HAIKU_MODEL="hermes3:8b"
# SUBAGENT_MODEL="hermes3:8b"

# --- Everything below is auto-generated by: ./generate-settings env >> .env ---
# IMPORTANT: Variables in .env are NOT exported to subprocesses.
# Source with `set -a` to auto-export, or use a shell alias/function:
#
#   claude() { set -a; source /path/to/.env; set +a; command claude "$@"; }
#
# ANTHROPIC_BASE_URL="http://$LITELLM_HOST:$LITELLM_PORT"
# ANTHROPIC_AUTH_TOKEN="$LITELLM_API_KEY"
# ANTHROPIC_DEFAULT_HAIKU_MODEL="hermes3:8b"
# ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-flash"
# CLAUDE_CODE_SUBAGENT_MODEL="hermes3:8b"
# ANTHROPIC_MODEL="sonnet"
